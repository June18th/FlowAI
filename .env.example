# ============================================================
# FlowAI 环境配置（统一根目录）
# ============================================================
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# ── 服务端口 ────────────────────────────────────────────────
FLOWAGENT_SERVER_PORT=8084

# ── MySQL ───────────────────────────────────────────────────
FLOWAGENT_MYSQL_HOST=localhost
FLOWAGENT_MYSQL_PORT=3306
FLOWAGENT_MYSQL_DATABASE=flowagent
FLOWAGENT_MYSQL_USERNAME=root
FLOWAGENT_MYSQL_PASSWORD=root123

# ── Redis ───────────────────────────────────────────────────
FLOWAGENT_REDIS_HOST=localhost
FLOWAGENT_REDIS_PORT=6379
FLOWAGENT_REDIS_PASSWORD=
FLOWAGENT_REDIS_DB=0

# ── MinIO ──────────────────────────────────────────────────
FLOWAGENT_MINIO_ENDPOINT=http://localhost:9000
FLOWAGENT_MINIO_ACCESS_KEY=minioadmin
FLOWAGENT_MINIO_SECRET_KEY=minioadmin
FLOWAGENT_MINIO_BUCKET_NAME=flowagent
FLOWAGENT_MINIO_PUBLIC_URL=http://localhost:9000

# ── Auth ────────────────────────────────────────────────────
FLOWAGENT_JWT_SECRET=
FLOWAGENT_DEFAULT_USERNAME=admin
FLOWAGENT_DEFAULT_PASSWORD=admin123

# ── Skills ──────────────────────────────────────────────────
FLOWAGENT_SKILLS_PATH=skills

# ── 前端 (Vite) ─────────────────────────────────────────────
VITE_API_BASE_URL=/api
# VITE_API_PROXY_TARGET=http://localhost:8084
